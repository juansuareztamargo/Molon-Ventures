{
  "name": "molon-ventures-slingshot",
  "version": "1.0.0",
  "description": "A physics-based slingshot game with target system built with Phaser 3 and TypeScript",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["phaser", "typescript", "vite", "game", "slingshot", "target-system", "physics"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juansuareztamargo/Molon-Ventures.git"
  },
  "bugs": {
    "url": "https://github.com/juansuareztamargo/Molon-Ventures/issues"
  },
  "homepage": "https://github.com/juansuareztamargo/Molon-Ventures#readme",
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "sass": "^1.69.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}